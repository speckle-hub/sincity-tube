# SinCity — Environment Variables Reference
# Copy this to .env for local dev, or set in Render dashboard

# ─── Database (PlanetScale MySQL) ─────────────────────────
DB_NAME=sincity
DB_USER=
DB_PASSWORD=
DB_HOST=aws.connect.psdb.cloud
WP_TABLE_PREFIX=sc_

# ─── WordPress URLs ────────────────────────────────────────
WP_HOME=https://sincity.onrender.com
WP_SITEURL=https://sincity.onrender.com
FORCE_SSL=true

# ─── Scheduled Tasks ──────────────────────────────────────
DISABLE_WP_CRON=true

# ─── Authentication Salts & Keys ──────────────────────────
# Generate at: https://api.wordpress.org/secret-key/1.1/salt/
# Use ALL 8 values below (replace these examples)
AUTH_KEY=replace-with-random-key
SECURE_AUTH_KEY=replace-with-random-key
LOGGED_IN_KEY=replace-with-random-key
NONCE_KEY=replace-with-random-key
AUTH_SALT=replace-with-random-key
SECURE_AUTH_SALT=replace-with-random-key
LOGGED_IN_SALT=replace-with-random-key
NONCE_SALT=replace-with-random-key

# ─── Debug (set true only during development) ─────────────
WP_DEBUG=false
