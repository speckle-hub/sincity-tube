# ═══════════════════════════════════════════════════════════════════════
# SinCity — Environment Variables (Render Dashboard)
# Copy this file, fill values, and set in Render > Environment
# ═══════════════════════════════════════════════════════════════════════

# ─── WordPress URLs ──────────────────────────────────────────
WP_HOME=https://sincity.porn
WP_SITEURL=https://sincity.porn
FORCE_SSL=true

# ─── Database (set automatically if using Render PostgreSQL) ──
DB_HOST=<Render PostgreSQL Internal Host>
DB_NAME=sincity
DB_USER=sincity
DB_PASSWORD=<generate-a-strong-password>

# ─── WordPress Salts (generate at https://api.wordpress.org/secret-key/1.1/salt/) ──
AUTH_KEY=<64-char-random-string>
SECURE_AUTH_KEY=<64-char-random-string>
LOGGED_IN_KEY=<64-char-random-string>
NONCE_KEY=<64-char-random-string>
AUTH_SALT=<64-char-random-string>
SECURE_AUTH_SALT=<64-char-random-string>
LOGGED_IN_SALT=<64-char-random-string>
NONCE_SALT=<64-char-random-string>

# ─── WP Table Prefix ─────────────────────────────────────────
WP_TABLE_PREFIX=sc_

# ─── Cron ────────────────────────────────────────────────────
DISABLE_WP_CRON=true

# ─── Debug ───────────────────────────────────────────────────
WP_DEBUG=false

# ─── Cloudflare R2 (for persistent uploads) ──────────────────
# Optional — only if using R2 for file storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sincity-uploads
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
